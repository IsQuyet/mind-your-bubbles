{
	"schemaVersion": 1,
	"id": "air-bar-tweaks",
	"version": "${version}",
	"name": "Air Bar Tweaks",
	"description": "A client-side Minecraft mod that lets you configure when the vanilla air bar is displayed.",
	"authors": [
		"Quyet"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/air-bar-tweaks/icon.png",
	"environment": "client",
	"entrypoints": {
		"client": [
			"io.github.isquyet.airbartweaks.client.AirBarTweaksClient"
		]
	},
	"mixins": [
		{
			"config": "air-bar-tweaks.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": "~1.21.11",
		"java": ">=21",
		"fabric-api": "*"
	}
}